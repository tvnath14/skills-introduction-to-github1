{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExpenseTrackerSyncPayload",
  "type": "object",
  "required": ["meta", "transactions", "categories", "settings"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["device_id", "last_sync", "row_counts"],
      "properties": {
        "device_id": { "type": "string", "description": "UUID of the sending device" },
        "last_sync": { "type": "string", "format": "date-time" },
        "row_counts": {
          "type": "object",
          "patternProperties": {
            "^[0-9]{4}-[0-9]{2}$": { "type": "integer" }
          },
          "additionalProperties": false,
          "description": "Row counts grouped by YYYY-MM month for delta negotiation"
        }
      }
    },
    "transactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "amount", "type", "category_id", "source", "month", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string" },
          "date": { "type": "string" },
          "amount": { "type": "number" },
          "type": { "type": "string", "enum": ["debit", "credit"] },
          "merchant": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] },
          "category_id": { "type": "string" },
          "raw_sms": { "type": ["string", "null"], "description": "AES-GCM encrypted payload" },
          "source": { "type": "string", "enum": ["sms", "manual"] },
          "confidence": { "type": ["number", "null"] },
          "flagged": { "type": ["integer", "null"] },
          "month": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "synced_at": { "type": ["string", "null"], "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "icon": { "type": ["string", "null"] },
          "is_default": { "type": ["integer", "null"] },
          "keywords": { "type": ["string", "null"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "settings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "value"],
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
